<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  Cisco-flavoured presence SUBSCRIBE + initial NOTIFY round-trip.

  Drives endpoint 1010 (subscriber, from tests/ci/pjsip.conf)
  through a SUBSCRIBE Event: presence for endpoint 1050 (watched
  exten, also from tests/ci/pjsip.conf), and asserts the NOTIFY
  body asterisk pushes carries the Cisco-private RPID namespace
  the res_pjsip_cisco_pidf_body_generator module emits.

  Flow:
    1. SUBSCRIBE Event: presence, Expires: 3600.
    2. asterisk 401 with WWW-Authenticate.
    3. SUBSCRIBE with Authorization (SIPp [authentication username=1010 password=ci-no-secret]).
    4. asterisk 200 OK (subscription accepted).
    5. asterisk pushes an immediate NOTIFY with the current
       presence state for 1050; assert the body matches the
       Cisco PIDF shape (xmlns:ce points at the Cisco RPID
       namespace; <presence> root element present).
    6. SIPp responds 200 OK to the NOTIFY.

  Subscription expires after SIPp exits (no explicit unsubscribe
  — the runner asterisk is restarted between matrix cells so
  state cleanup isn't load-bearing here).

  Wire-format coverage this scenario adds beyond
  register_optionsind.xml:
    * Inbound SUBSCRIBE through the auth challenge
    * res_pjsip_cisco_pidf_body_generator's NOTIFY body shape
      via a real subscription (the unit test test_blf_pidf
      covers the same builder in isolation)
-->
<scenario name="cisco_subscribe_presence">

  <!-- ============================================================
       Step 1: initial SUBSCRIBE (no Authorization).
       ============================================================ -->
  <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:1050@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/TCP [local_ip]:[local_port];rport;branch=[branch]
      From: <sip:1010@[remote_ip]>;tag=[call_number]
      To: <sip:1050@[remote_ip]>
      Call-ID: [call_id]
      CSeq: 1 SUBSCRIBE
      User-Agent: Cisco-CP8865/12.1.1
      Max-Forwards: 70
      Contact: <sip:1010@[local_ip]:[local_port];transport=tcp>
      Event: presence
      Accept: application/pidf+xml
      Expires: 3600
      Content-Length: 0

    ]]>
  </send>

  <!-- ============================================================
       Step 2: 401 Unauthorized — capture the challenge.
       ============================================================ -->
  <recv response="401" auth="true">
  </recv>

  <!-- ============================================================
       Step 3: SUBSCRIBE with Authorization.
       ============================================================ -->
  <send retrans="500">
    <![CDATA[

      SUBSCRIBE sip:1050@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/TCP [local_ip]:[local_port];rport;branch=[branch]
      From: <sip:1010@[remote_ip]>;tag=[call_number]
      To: <sip:1050@[remote_ip]>
      Call-ID: [call_id]
      CSeq: 2 SUBSCRIBE
      User-Agent: Cisco-CP8865/12.1.1
      Max-Forwards: 70
      Contact: <sip:1010@[local_ip]:[local_port];transport=tcp>
      Event: presence
      Accept: application/pidf+xml
      [authentication username=1010 password=ci-no-secret]
      Expires: 3600
      Content-Length: 0

    ]]>
  </send>

  <!-- ============================================================
       Step 4: 200 OK — subscription accepted.
       ============================================================ -->
  <recv response="200">
  </recv>

  <!-- ============================================================
       Step 5: NOTIFY pushed by asterisk with current presence
       state. Assert the body carries the Cisco-private RPID
       namespace declaration (xmlns:ce) — that's the marker
       res_pjsip_cisco_pidf_body_generator adds beyond stock
       res_pjsip_pidf_body_generator's output.
       ============================================================ -->
  <recv request="NOTIFY" crlf="true">
    <action>
      <ereg regexp="urn:cisco:params:xml:ns:pidf:rpid" search_in="msg" check_it="true" assign_to="cisco_ns"/>
      <ereg regexp="&lt;presence"                     search_in="msg" check_it="true" assign_to="presence_root"/>
    </action>
  </recv>

  <!-- ============================================================
       Step 6: SIPp ACKs the NOTIFY with 200 OK. Without this
       asterisk would retransmit the NOTIFY (RFC 6665) and the
       scenario would time out. X-Test-Asserts echoes the eregs'
       captures (see bulkupdate_refer.xml for the rationale).
       ============================================================ -->
  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      X-Test-Asserts: [$cisco_ns] [$presence_root]
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 20, 30, 50, 100, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000"/>

</scenario>
