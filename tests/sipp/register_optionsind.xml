<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  Cisco-flavoured REGISTER round-trip.

  Drives endpoint 1010 (from tests/ci/pjsip.conf) through a full
  REGISTER cycle with the headers a real Cisco Enterprise SIP phone
  sends, and asserts the 200 OK response carries the multipart
  RemoteCC optionsind body our res_pjsip_cisco_register_optionsind
  module emits.

  Flow:
    1. REGISTER with Cisco Contact (+sip.instance MAC, reg-id) and
       a Reason header carrying Name / ActiveLoad /
       InactiveLoad — the v0.5.0 PATH C harvest path.
    2. asterisk responds 401 Unauthorized with WWW-Authenticate.
    3. REGISTER with Authorization (SIPp computes the digest from
       the captured WWW-Authenticate via [authentication username=1010 password=ci-no-secret]).
    4. asterisk responds 200 OK; assert the response body matches
       the optionsind multipart shape we emit.
    5. De-register (Expires: 0).
    6. asterisk responds 200 OK.

  Side-effects this scenario exercises (verified post-run via
  `pjsip cisco status 1010`, see ../sipp/run.sh):
    * res_pjsip_cisco_register_optionsind attaches the multipart
      optionsind body to the 200 OK (1 -> 4).
    * res_pjsip_cisco_feature_events MAC harvest extracts
      aabbccddeeff from +sip.instance.
    * Reason-header parsing populates device name + firmware loads.

  The UUID 00000000-0000-0000-0000-aabbccddeeff is intentionally
  bogus-looking; it matches the +sip.instance format Cisco firmware
  generates but uses a sentinel MAC so test failures aren't confused
  with bench-phone traffic.
-->
<scenario name="cisco_register_optionsind">

  <!-- ============================================================
       Step 1: initial REGISTER (no Authorization).
       ============================================================ -->
  <send retrans="500">
    <![CDATA[

      REGISTER sip:[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/TCP [local_ip]:[local_port];rport;branch=[branch]
      From: <sip:1010@[remote_ip]>;tag=[call_number]
      To: <sip:1010@[remote_ip]>
      Call-ID: [call_id]
      CSeq: 1 REGISTER
      User-Agent: Cisco-CP8865/12.1.1
      Max-Forwards: 70
      Contact: <sip:1010@[local_ip]:[local_port];transport=tcp>;+sip.instance="<urn:uuid:00000000-0000-0000-0000-aabbccddeeff>";reg-id=1
      Reason: SIP;cause=200;text="Name=SEPAABBCCDDEEFF ActiveLoad=sip8865.12-1-1-12 InactiveLoad=sip8865.cert-2014"
      Expires: 3600
      Content-Length: 0

    ]]>
  </send>

  <!-- ============================================================
       Step 2: 401 Unauthorized — capture the challenge.
       ============================================================ -->
  <recv response="401" auth="true">
  </recv>

  <!-- ============================================================
       Step 3: REGISTER with Authorization. SIPp's [authentication]
       macro computes the digest response from the captured
       WWW-Authenticate header in step 2, using the username +
       password specified inline below. Each scenario embeds its
       own credentials (rather than -au / -ap on the command line)
       because the scenarios use different endpoints in
       tests/ci/pjsip.conf.
       ============================================================ -->
  <send retrans="500">
    <![CDATA[

      REGISTER sip:[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/TCP [local_ip]:[local_port];rport;branch=[branch]
      From: <sip:1010@[remote_ip]>;tag=[call_number]
      To: <sip:1010@[remote_ip]>
      Call-ID: [call_id]
      CSeq: 2 REGISTER
      User-Agent: Cisco-CP8865/12.1.1
      Max-Forwards: 70
      Contact: <sip:1010@[local_ip]:[local_port];transport=tcp>;+sip.instance="<urn:uuid:00000000-0000-0000-0000-aabbccddeeff>";reg-id=1
      Reason: SIP;cause=200;text="Name=SEPAABBCCDDEEFF ActiveLoad=sip8865.12-1-1-12 InactiveLoad=sip8865.cert-2014"
      [authentication username=1010 password=ci-no-secret]
      Expires: 3600
      Content-Length: 0

    ]]>
  </send>

  <!-- ============================================================
       Step 4: 200 OK — must contain the optionsind body. Asserted
       via two regexes: the outer XML element and one inner field
       name. The full multipart shape varies (boundary, content
       type, ordering); we don't pin the byte-exact form here —
       the body templates have their own well-formedness test in
       tests/unit/test_xml_bodies.c.
       ============================================================ -->
  <recv response="200">
    <action>
      <ereg regexp="x-cisco-remotecc-response" search_in="msg" check_it="true" assign_to="optionsind_outer"/>
      <ereg regexp="&lt;optionsind&gt;"        search_in="msg" check_it="true" assign_to="optionsind_inner"/>
    </action>
  </recv>

  <!-- ============================================================
       Step 5: de-register so the contact doesn't linger in the
       AOR past the test (matters if subsequent tests query
       'pjsip show endpoint 1010'). X-Test-Asserts echoes the
       eregs' captured values so sip-tester 3.7 sees each variable
       referenced downstream (see bulkupdate_refer.xml for the
       rationale).
       ============================================================ -->
  <send retrans="500">
    <![CDATA[

      REGISTER sip:[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/TCP [local_ip]:[local_port];rport;branch=[branch]
      From: <sip:1010@[remote_ip]>;tag=[call_number]
      To: <sip:1010@[remote_ip]>
      Call-ID: [call_id]
      CSeq: 3 REGISTER
      User-Agent: Cisco-CP8865/12.1.1
      Max-Forwards: 70
      Contact: <sip:1010@[local_ip]:[local_port];transport=tcp>;+sip.instance="<urn:uuid:00000000-0000-0000-0000-aabbccddeeff>";reg-id=1
      X-Test-Asserts: [$optionsind_outer] [$optionsind_inner]
      [authentication username=1010 password=ci-no-secret]
      Expires: 0
      Content-Length: 0

    ]]>
  </send>

  <recv response="401" auth="true" optional="true">
  </recv>

  <recv response="200">
  </recv>

  <!-- Default response-time and call-length timeouts; SIPp ends
       the call automatically after the last recv. -->
  <ResponseTimeRepartition value="10, 20, 30, 50, 100, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000"/>

</scenario>
